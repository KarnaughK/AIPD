#!/bin/bash
set -e

if [ -z "$1" ]; then
    echo "用法: aipd-skill/scripts/install-project <项目路径>"
    echo "示例: aipd-skill/scripts/install-project /Users/xxx/my-project"
    exit 1
fi

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PROJECT_ROOT="$(dirname "$SCRIPT_DIR")"
DIST_DIR="$PROJECT_ROOT/dist/claude/skills"
TARGET_DIR="$1/.claude/skills"

"$SCRIPT_DIR/build" claude

mkdir -p "$TARGET_DIR"

for legacy in \
    aipd2 aipd2-case-create aipd2-case-run aipd2-case-archive aipd2-weave aipd2-inbox aipd2-learn aipd2-update aipd2-git-push \
    aipd2-plan-create aipd2-plan-run aipd2-plan-archive aipd2-plan-learn \
    aipd-plan-create aipd-plan-run aipd-plan-archive aipd-plan-learn \
    mermaid-preview; do
    target="$TARGET_DIR/$legacy"
    if [ -e "$target" ] || [ -L "$target" ]; then
        rm -rf "$target"
        echo "移除旧 skill: $target"
    fi
done

for skill_dir in "$DIST_DIR"/*/; do
    name=$(basename "$skill_dir")
    target="$TARGET_DIR/$name"
    rm -rf "$target"
    cp -r "$skill_dir" "$target"
    echo "安装: $target"
done

echo ""
echo "安装完成。skill 已复制到 $TARGET_DIR/"
