#!/bin/bash
set -e

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/legacy-skills"
PROJECT_ROOT="$(dirname "$SCRIPT_DIR")"
DIST_DIR="$PROJECT_ROOT/dist/codex/skills"
AGENTS_DIST_DIR="$PROJECT_ROOT/dist/codex/agents"
TARGET_DIR="$HOME/.codex/skills"
AGENTS_TARGET_DIR="$HOME/.codex/agents"

"$SCRIPT_DIR/build" codex

mkdir -p "$TARGET_DIR"
mkdir -p "$AGENTS_TARGET_DIR"

for legacy in "${AIPD_LEGACY_SKILLS[@]}"; do
    target="$TARGET_DIR/$legacy"
    if [ -e "$target" ] || [ -L "$target" ]; then
        rm -rf "$target"
        echo "移除旧 skill: $target"
    fi
done

for legacy in frontend-architect aipd-frontend-architect aipd-vue-architect aipd-vue-provider; do
    target="$AGENTS_TARGET_DIR/$legacy.toml"
    if [ -e "$target" ] || [ -L "$target" ]; then
        rm -rf "$target"
        echo "移除旧 agent: $target"
    fi
done

for skill_dir in "$DIST_DIR"/*/; do
    name=$(basename "$skill_dir")
    target="$TARGET_DIR/$name"
    if [ -L "$target" ]; then
        rm "$target"
    elif [ -d "$target" ]; then
        echo "警告: $target 是真实目录，跳过（请手动处理）"
        continue
    fi
    ln -s "$skill_dir" "$target"
    echo "链接: $target → $skill_dir"
done

if [ -d "$AGENTS_DIST_DIR" ]; then
    for agent_file in "$AGENTS_DIST_DIR"/*.toml; do
        [ -e "$agent_file" ] || continue
        name=$(basename "$agent_file")
        target="$AGENTS_TARGET_DIR/$name"
        if [ -L "$target" ]; then
            rm "$target"
        elif [ -e "$target" ]; then
            echo "警告: $target 已存在，跳过（请手动处理）"
            continue
        fi
        ln -s "$agent_file" "$target"
        echo "链接 agent: $target → $agent_file"
    done
fi

echo ""
echo "Codex 开发模式安装完成。修改源码后运行 aipd-skill/scripts/build 即可更新。"
