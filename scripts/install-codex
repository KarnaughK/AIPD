#!/bin/bash
set -e

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PROJECT_ROOT="$(dirname "$SCRIPT_DIR")"
DIST_DIR="$PROJECT_ROOT/dist/codex/skills"
TARGET_DIR="$HOME/.codex/skills"

"$SCRIPT_DIR/build" codex

mkdir -p "$TARGET_DIR"

for legacy in aipd2-plan-create aipd2-plan-run aipd2-plan-archive aipd2-plan-learn; do
    target="$TARGET_DIR/$legacy"
    if [ -e "$target" ] || [ -L "$target" ]; then
        rm -rf "$target"
        echo "移除旧 skill: $target"
    fi
done

for skill_dir in "$DIST_DIR"/*/; do
    name=$(basename "$skill_dir")
    target="$TARGET_DIR/$name"
    rm -rf "$target"
    cp -r "$skill_dir" "$target"
    echo "安装: $target"
done

echo ""
echo "Codex 安装完成。skill 已复制到 $TARGET_DIR/"
